<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Support Request Received</title>
  </head>
  <body
    style="margin: 0; padding: 0; font-family: 'Roboto', Arial, sans-serif; background-color: #f3f4f6; color: #1f2937;"
  >
    <div
      style='max-width: 640px; margin: 40px auto; background-color: #ffffff; border-radius: 12px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); overflow: hidden;'
    >
      <table
        role='presentation'
        cellspacing='0'
        cellpadding='0'
        style='width: 100%; table-layout: fixed;'
      >
        <tr>
          <td
            style='padding: 30px; background-color: #BEDBB0; text-align: center;'
          >
            <h1
              style='margin: 0; font-size: 28px; color: #161616; font-weight: 600;'
            >Support Request Received</h1>
          </td>
        </tr>
        <tr>
          <td style='padding: 24px;'>
            <p
              style='font-size: 16px; line-height: 1.6; color: #374151; margin: 16px 0;'
            >Hello {{userName}},</p>
            <p
              style='font-size: 16px; line-height: 1.6; color: #374151; margin: 16px 0;'
            >
              We have received your support request with the following details:
            </p>
            <p
              style='font-size: 16px; line-height: 1.6; color: #374151; margin: 16px 0;'
            ><strong>Case ID:</strong> {{caseId}}</p>
            <p
              style='font-size: 16px; line-height: 1.6; color: #374151; margin: 16px 0;'
            ><strong>Description:</strong> {{description}}</p>
            <p
              style='font-size: 16px; line-height: 1.6; color: #374151; margin: 16px 0;'
            >
              Our team will review your request and respond as soon as possible.
              If you have additional information, please reply to this email
              with your Case ID.
            </p>
            <p
              style='font-size: 16px; line-height: 1.6; color: #374151; margin: 16px 0;'
            >Thank you for reaching out!</p>
          </td>
        </tr>
        <tr>
          <td
            style='text-align: center; padding: 20px; background-color: #f9fafb; font-size: 14px; color: #6b7280;'
          >
            <p style='margin: 0;'>&copy;
              {{year}}
              Task Pro. All rights reserved.</p>
            <p style='margin: 0;'>
              <a
                href='{{privacyPolicyLink}}'
                target='_blank'
                style='color: #BEDBB0; text-decoration: none; margin: 0 8px;'
              >Privacy Policy</a>
              |
              <a
                href='{{supportLink}}'
                target='_blank'
                style='color: #BEDBB0; text-decoration: none; margin: 0 8px;'
              >Contact Support</a>
            </p>
          </td>
        </tr>
      </table>
    </div>
  </body>
</html>